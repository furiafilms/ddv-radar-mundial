{
  "version": "v216-tv-argentina-scanner-estable",
  "note": "Fuentes vivas para TV/Cable Argentina. V216 usa fuentes principales AmericaTVGuide y deja TeleRed/Artear como secundarias no bloqueantes; falla solo si ninguna fuente principal argentina parsea programación.",
  "sources": [
    {
      "id": "telered_buscador_grilla",
      "type": "telered_grid",
      "provider": "TeleRed / grilla de programación",
      "url": "https://www.telered.com.ar/buscador-grilla",
      "enabled": true,
      "critical": false,
      "timeout": 60,
      "retries": 1,
      "channels": [
        "CINE.AR",
        "CANAL A",
        "VOLVER",
        "Film & Arts"
      ],
      "min_programmes": 50,
      "primary": false,
      "block_workflow_on_fail": false
    },
    {
      "id": "america_tvguide_cinear",
      "type": "america_tvguide_channel",
      "provider": "AmericaTVGuide / CINE.AR",
      "url": "https://americatvguide.com/es/ar/channel/cine_ar",
      "channel": "CINE.AR",
      "channel_number": "CINE.AR · TDA/operadores argentinos",
      "enabled": true,
      "critical": false,
      "timeout": 45,
      "retries": 1,
      "min_programmes": 10,
      "primary": true,
      "block_workflow_on_fail": false
    },
    {
      "id": "america_tvguide_canala",
      "type": "america_tvguide_channel",
      "provider": "AmericaTVGuide / Canal á",
      "url": "https://americatvguide.com/es/ar/channel/canal_a",
      "channel": "Canal á",
      "channel_number": "Canal á · señal según operador",
      "enabled": true,
      "critical": false,
      "timeout": 45,
      "retries": 1,
      "min_programmes": 10,
      "primary": true,
      "block_workflow_on_fail": false
    },
    {
      "id": "america_tvguide_volver",
      "type": "america_tvguide_channel",
      "provider": "AmericaTVGuide / Canal Volver",
      "url": "https://americatvguide.com/es/ar/channel/canal_volver",
      "channel": "VOLVER",
      "channel_number": "VOLVER · señal según operador",
      "enabled": true,
      "critical": false,
      "timeout": 45,
      "retries": 1,
      "primary": true,
      "block_workflow_on_fail": false,
      "min_programmes": 5
    },
    {
      "id": "artear_canala_comercial",
      "type": "artear_weekly",
      "provider": "Artear / grilla comercial Canal A",
      "url_template": "https://www.canal13.artear.com.ar/mkt/progytarifas/caa/programacion/CAA-PRO-{year}-{week:02d}-01.html",
      "channel": "Canal á",
      "channel_number": "Canal á · Artear comercial",
      "enabled": true,
      "critical": false,
      "past_weeks": 1,
      "future_weeks": 8,
      "timeout": 45,
      "retries": 1,
      "min_programmes": 1,
      "fallback_url_template": "https://appsprepo.canal13.artear.com.ar/progytarifas/caa/tarifas/CAA-COM-{year}-{week:02d}-01.html",
      "primary": false,
      "block_workflow_on_fail": false
    }
  ]
}
